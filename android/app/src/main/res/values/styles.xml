<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#00000a</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <!-- Hand off to the real app theme after the splash animation finishes
             so our status/nav bar colors, fullscreen, and cutout mode actually
             apply at runtime instead of the Theme.SplashScreen defaults. -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <!-- Mirror the dark bar overrides so the splash frame itself renders
             with #00000a bars + light icons, no white flash on launch. -->
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#00000a</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>